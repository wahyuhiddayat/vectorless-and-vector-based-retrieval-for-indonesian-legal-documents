# Architecture, vectorless vs vector retrieval for Indonesian legal documents.
# Render at https://play.d2lang.com, then export the result to assets/architecture.svg.

direction: right

scraper: "Scraper\n(scraper/)" {
  shape: rectangle
}

raw: "data/raw/" {
  shape: cylinder
}

indexing: "Indexing\n(vectorless/indexing/)\nLLM parse, OCR clean, re-split, summary" {
  shape: rectangle
}

index: "Shared index\ndata/index_{pasal, ayat, rincian}/" {
  shape: cylinder
}

vectorless: "Vectorless RAG\n(vectorless/retrieval/)" {
  bm25: BM25
  hybrid: "Hybrid (BM25 + LLM)"
  llm: "LLM navigation"
}

vector: "Vector RAG\n(vector/)" {
  dense: "Qdrant dense + optional reranker"
}

evaluation: "Evaluation\n(scripts/)" {
  gt: "Ground truth"
  eval: "Eval harness + significance test"
}

scraper -> raw -> indexing -> index
index -> vectorless: reads
index -> vector: reads
vectorless -> evaluation
vector -> evaluation
